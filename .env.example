# ============================================================================
# Objetivo: Definición de variables de entorno para el Asistente Digital.
# Usuario: Administrador / Desarrollador.
# Casos de Uso: Configuración del entorno de ejecución (.env).
# ============================================================================

# --- Configuración de Base de Datos (PostgreSQL) ---
DB_URL=jdbc:postgresql://localhost:5432/assistant_pro
DB_USER=user_admin
DB_PASS=

# --- Memoria de Trabajo (Redis) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Mensajería (Kafka) ---
KAFKA_SERVERS=localhost:9092

# --- Inteligencia Artificial (Google Gemini) ---
# Obtener en https://aistudio.google.com/
GEMINI_AUTH_MODE=api-key
GEMINI_API_KEY=
GEMINI_OAUTH2_TOKEN=
GEMINI_OAUTH2_TOKEN_URL=
GEMINI_OAUTH2_CLIENT_ID=
GEMINI_OAUTH2_CLIENT_SECRET=
GEMINI_OAUTH2_SCOPE=
GEMINI_OAUTH2_AUDIENCE=

# --- Inteligencia Artificial (Groq/Grok) ---
# Obtener en https://console.groq.com/
GROK_AUTH_MODE=api-key
GROQ_API_KEY=
GROK_OAUTH2_TOKEN=
GROK_OAUTH2_TOKEN_URL=
GROK_OAUTH2_CLIENT_ID=
GROK_OAUTH2_CLIENT_SECRET=
GROK_OAUTH2_SCOPE=
GROK_OAUTH2_AUDIENCE=

# --- Inteligencia Artificial (OpenAI/ChatGPT) ---
# Obtener en https://platform.openai.com/api-keys
CHATGPT_AUTH_MODE=api-key
OPENAI_API_KEY=
CHATGPT_OAUTH2_TOKEN=
CHATGPT_OAUTH2_TOKEN_URL=
CHATGPT_OAUTH2_CLIENT_ID=
CHATGPT_OAUTH2_CLIENT_SECRET=
CHATGPT_OAUTH2_SCOPE=
CHATGPT_OAUTH2_AUDIENCE=

# --- Interfaz (Telegram) ---
# Obtener en @BotFather
TELEGRAM_BOT_USERNAME=Jmp_hal_bot
TELEGRAM_BOT_TOKEN=